{
  "name": "worldclass-erp-backend",
  "version": "1.0.0",
  "description": "Backend API for Worldclass ERP",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "db:migrate": "ts-node src/config/migrations.ts",
    "db:seed": "ts-node src/config/seed.ts",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "db:dimensions": "ts-node src/config/dimensions-migration.ts && ts-node src/config/dimensions-seed.ts",
    "db:periods": "ts-node src/config/period-migration.ts && ts-node src/config/period-seed.ts",
    "db:full-setup": "npm run db:migrate && npm run db:seed && npm run db:dimensions && npm run db:periods",
    "db:multi-tenant": "ts-node src/config/run-multi-tenant-migration.ts",
    "seed:demo": "psql \"$DATABASE_URL\" -f database/demo-tenant-fix.sql"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "@aws-sdk/client-textract": "^3.931.0",
    "@sentry/node": "^10.29.0",
    "@sentry/profiling-node": "^10.29.0",
    "@types/bcrypt": "^6.0.0",
    "@types/bull": "^3.15.9",
    "@types/ioredis": "^4.28.10",
    "@types/multer": "^2.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.3",
    "@types/pg": "^8.15.6",
    "aws-sdk": "^2.1692.0",
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.0",
    "helmet": "^7.2.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.10.1",
    "openai": "^6.8.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.16.3",
    "socket.io": "^4.8.1",
    "stripe": "^19.3.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^6.4.21",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
