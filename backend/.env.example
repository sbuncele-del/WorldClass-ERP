# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/worldclass_erp
DB_HOST=localhost
DB_PORT=5432
DB_NAME=worldclass_erp
DB_USER=username
DB_PASSWORD=password

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=1h
REFRESH_TOKEN_EXPIRY=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Payment Gateway - Ozow (South Africa)
# Apply for account at: https://www.ozow.com/
OZOW_SITE_CODE=your_ozow_site_code
OZOW_PRIVATE_KEY=your_ozow_private_key
OZOW_API_KEY=your_ozow_api_key
OZOW_BASE_URL=https://pay.ozow.com
OZOW_IS_TEST=true

# Payment Gateway - Stripe (International)
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Application URLs
APP_URL=http://localhost:5173
API_URL=http://localhost:3000

# Email Configuration
# Choose ONE provider below:

# Option 1: Amazon SES (Recommended for AWS)
# EMAIL_PROVIDER=ses
# AWS_SES_REGION=eu-north-1
# AWS_SES_ACCESS_KEY_ID=your_ses_access_key
# AWS_SES_SECRET_ACCESS_KEY=your_ses_secret_key

# Option 2: SendGrid (Free tier: 100 emails/day)
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.xxxxxx

# Option 3: Generic SMTP (Gmail, Outlook, etc.)
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Common settings (all providers)
EMAIL_FROM=noreply@aetheros.co.za
EMAIL_FROM_NAME=WorldClass ERP
ENABLE_EMAIL=true
FRONTEND_URL=http://localhost:5173

# Redis Configuration (for job queues and caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# AWS Configuration (for Textract OCR)
# Get credentials from AWS IAM Console: https://console.aws.amazon.com/iam/
# Required IAM permissions: textract:DetectDocumentText, textract:AnalyzeDocument
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
REDIS_TLS=false

# AWS S3 Configuration (for invoices and documents)
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET_NAME=aetheros-erp-invoices
