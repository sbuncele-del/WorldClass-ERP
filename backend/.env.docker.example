# ========================================
# WorldClass ERP - Docker Environment Variables
# ========================================
#
# INSTRUCTIONS:
# 1. Copy this file to .env.docker
# 2. Fill in all values marked with <CHANGE_ME>
# 3. NEVER commit .env.docker to git!
#
# ========================================

# ----------------------------------------
# Node.js Environment
# ----------------------------------------
NODE_ENV=production
PORT=3000

# ----------------------------------------
# Database (PostgreSQL)
# ----------------------------------------
# For Docker Compose (local DB container):
DATABASE_URL=postgresql://postgres:postgres@db:5432/worldclass_erp
PGHOST=db
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=worldclass_erp
PGSSLMODE=disable

# For AWS RDS (uncomment and fill in):
# DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>
# PGHOST=<your-rds-endpoint>.rds.amazonaws.com
# PGPORT=5432
# PGUSER=<username>
# PGPASSWORD=<CHANGE_ME>
# PGDATABASE=worldclass_erp
# PGSSLMODE=require

# ----------------------------------------
# Redis (Cache/Session)
# ----------------------------------------
# For Docker Compose (local Redis container):
REDIS_HOST=redis
REDIS_PORT=6379

# For AWS ElastiCache (uncomment and fill in):
# REDIS_HOST=<your-elasticache-endpoint>
# REDIS_PORT=6379

# ----------------------------------------
# Authentication (JWT)
# ----------------------------------------
JWT_SECRET=<CHANGE_ME_GENERATE_RANDOM_64_CHAR_STRING>
JWT_REFRESH_SECRET=<CHANGE_ME_GENERATE_DIFFERENT_64_CHAR_STRING>
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# ----------------------------------------
# AI Services (x.ai/Grok - PRIMARY)
# ----------------------------------------
# Get your API key from: https://console.x.ai
XAI_API_KEY=<CHANGE_ME>

# Fallback AI providers (optional)
# OPENAI_API_KEY=<optional>
# ANTHROPIC_API_KEY=<optional>
# GROQ_API_KEY=<optional - free tier available>

# ----------------------------------------
# Email Service (Resend)
# ----------------------------------------
# Get your API key from: https://resend.com
RESEND_API_KEY=<CHANGE_ME>
EMAIL_FROM=noreply@yourdomain.com

# Legacy SMTP (if not using Resend)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=<CHANGE_ME>

# ----------------------------------------
# AWS Services (Textract, S3)
# ----------------------------------------
AWS_ACCESS_KEY_ID=<CHANGE_ME>
AWS_SECRET_ACCESS_KEY=<CHANGE_ME>
AWS_REGION=us-east-1
AWS_S3_BUCKET=worldclass-erp-uploads

# ----------------------------------------
# Video Meetings (Daily.co)
# ----------------------------------------
DAILY_API_KEY=<CHANGE_ME>
DAILY_DOMAIN=<your-domain>.daily.co

# ----------------------------------------
# CORS Configuration
# ----------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGIN=https://yourdomain.com,http://localhost:5173

# ----------------------------------------
# Logging
# ----------------------------------------
LOG_LEVEL=info

# ----------------------------------------
# Rate Limiting
# ----------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
