<svg width="512" height="512" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e40af"/>
      <stop offset="100%" style="stop-color:#3b82f6"/>
    </linearGradient>
  </defs>
  <!-- Background -->
  <rect width="512" height="512" rx="100" fill="url(#bg)"/>
  <!-- Truck Icon -->
  <g transform="translate(80, 140)" fill="white">
    <!-- Truck body -->
    <rect x="120" y="60" width="180" height="100" rx="8"/>
    <!-- Cabin -->
    <path d="M40,80 L120,80 L120,160 L40,160 L40,120 Q40,80 80,80 Z" fill="white"/>
    <!-- Window -->
    <rect x="50" y="90" width="60" height="40" rx="4" fill="#1e40af" opacity="0.5"/>
    <!-- Wheels -->
    <circle cx="90" cy="175" r="30" fill="white"/>
    <circle cx="90" cy="175" r="15" fill="#1e40af"/>
    <circle cx="250" cy="175" r="30" fill="white"/>
    <circle cx="250" cy="175" r="15" fill="#1e40af"/>
    <!-- Road marks -->
    <rect x="0" y="220" width="60" height="8" rx="4" fill="white" opacity="0.5"/>
    <rect x="80" y="220" width="60" height="8" rx="4" fill="white" opacity="0.5"/>
    <rect x="160" y="220" width="60" height="8" rx="4" fill="white" opacity="0.5"/>
    <rect x="240" y="220" width="60" height="8" rx="4" fill="white" opacity="0.5"/>
  </g>
  <!-- SiyaBusa text -->
  <text x="256" y="420" text-anchor="middle" font-family="Arial, sans-serif" font-size="48" font-weight="bold" fill="white">DRIVER</text>
</svg>
