# ============================================================
# WorldClass ERP - Oracle Cloud Environment Template
# ============================================================
# Copy this to .env and fill in your values
# ============================================================

# Database Password (change this!)
DB_PASSWORD=worldclass_secure_2024

# JWT Secrets (auto-generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-change-me
JWT_REFRESH_SECRET=your-refresh-secret-change-me

# Frontend URL (your Oracle VM public IP)
FRONTEND_URL=http://YOUR_PUBLIC_IP

# API URL for frontend build
VITE_API_URL=/api

# Optional: Email configuration
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Optional: Stripe (for payments)
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
