{
  "name": "worldclass-erp",
  "version": "1.0.0",
  "description": "World-class ERP Software System",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces"
  },
  "keywords": [
    "erp",
    "enterprise",
    "management"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "ioredis-mock": "^8.13.1"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/bull": "^4.10.4",
    "@types/ioredis": "^5.0.0",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "ioredis": "^5.8.2",
    "pg": "^8.16.3",
    "rate-limit-redis": "^4.3.1"
  }
}
